{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AAA",
  "version": "0.1.0",
  "identifier": "com.aaa.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Autonomous AI Assistant",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "label": "main",
        "visible": true
      },
      {
        "title": "Spotlight",
        "label": "spotlight",
        "width": 600,
        "height": 80,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "center": true
      },
      {
        "title": "Toast",
        "label": "toast",
        "width": 350,
        "height": 120,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "x": -20,
        "y": 20
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/backend"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
